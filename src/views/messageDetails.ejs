<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Message Details</title>
    <style>
        /* Modern, clean CSS styling */
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f3f4f6;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .message-card {
            background-color: white;
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
        }
        .author {
            font-size: 1.75rem;
            color: #111827;
            margin: 0 0 0.25rem 0;
        }
        .date {
            font-size: 0.875rem;
            color: #6b7280;
            display: block;
            margin-bottom: 1.5rem;
        }
        .text {
            font-size: 1.125rem;
            line-height: 1.6;
            color: #374151;
            padding: 1.25rem;
            background-color: #f9fafb;
            border-left: 4px solid #3b82f6; /* A nice blue accent line */
            border-radius: 4px;
            margin-bottom: 2rem;
        }
        .back-link {
            text-decoration: none;
            color: white;
            background-color: #3b82f6;
            padding: 0.6rem 1.2rem;
            border-radius: 6px;
            font-weight: 500;
            transition: background-color 0.2s;
        }
        .back-link:hover {
            background-color: #2563eb;
        }
    </style>
</head>
<body>

    <main class="message-card">
        <h1 class="author"><%= message.user %></h1>
        <span class="date"><%= message.added.toLocaleString() %></span>
        
        <div class="text">
            <%= message.text %>
        </div>
        
        <a href="/" class="back-link">← Back to Board</a>
    </main>

</body>
</html>
