<!-- index.ejs -->
<html>
  <head>
    <title>Homepage</title>
      <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
  <ul>
  <% messages.forEach((message) => { %>
    <li> <h3> <%= message.user %> </h3>
      <p> <%= message.text %> </p> 
      <small> <%= message.added.toLocaleString() %> </small>
    </li> <% }); %>
</ul>
  </body>
</html>


