<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Message Board</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <main class="board-container">
        <header class="board-header">
            <h1>Message Board</h1>
            <a href="/new" class="new-msg-btn">Write a New Message</a>
        </header>

        <ul class="message-list">
            <% messages.forEach((message)=> { %>
                <li class="message-card">
                    <div class="message-header">
                        <h3 class="author">
                            <%= message.username %>
                        </h3>
                        <small class="date">
                            <%= message.added_at ? message.added_at.toLocaleString() : 'No date' %>
                        </small>
                    </div>
                    <p class="text">
                        <%= message.text %>
                    </p>
                    <p class="id">
                        <%= message.id %>
                    </p>

                    <a href="/message/<%= message.id %>" class="open-btn">Open Details</a>
                </li>
                <% }); %>
        </ul>
    </main>
</body>

</html>
